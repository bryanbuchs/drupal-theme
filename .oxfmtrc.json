{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "jsxSingleQuote": true,
  "htmlWhitespaceSensitivity": "css",
  "vueIndentScriptAndStyle": false,
  "singleAttributePerLine": false,
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["*.css", "*.less"],
      "options": {
        "singleQuote": false
      }
    }
  ],
  "ignorePatterns": [
    "node_modules",
    "vendor",
    "dist",
    "build",
    "public/build",
    "*.min.js",
    "*.min.css",
    "coverage",
    ".nyc_output",
    "package-lock.json",
    "yarn.lock",
    "composer.lock"
  ]
}
