{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "storybook-static",
    "tokens/css"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "globals": {
    "__APP_LOCALE__": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  }
}
