        "$value": "{colors.black}",
        "$type": "color"
      }
    },
    "border": {
      "default": {
        "$value": "{colors.stone-dark}",
        "$type": "color"
      },
      "light": {
        "$value": "{colors.fog-light}",
        "$type": "color"
      }
    },
    "background": {
      "light": {
        "$value": "{colors.fog-light}",
        "$type": "color"
      }
    },
    "validation": {
      "valid": {
        "$value": "{colors.palo-verde}",
        "$type": "color"
      },
      "invalid": {
        "$value": "{colors.digital-red}",
        "$type": "color"
      }
    },
    "warning": {
      "$value": "{colors.poppy}",
      "$type": "color"
    },
    "input": {
